#!/usr/bin/env python3
"""Manage the active Codex guardrail state and run manual checks."""

from __future__ import annotations

import argparse
import datetime as dt
import re
from pathlib import Path


STATE_PATH = Path.home() / ".codex" / "guardrails" / "current.toml"
DESTRUCTIVE_PATTERNS = [
    (re.compile(r"\brm\s+(-[^\n]*r[^\n]*f|-rf|-fr|--recursive)\b"), "recursive delete"),
    (re.compile(r"\bDROP\s+(TABLE|DATABASE)\b", re.IGNORECASE), "destructive SQL"),
    (re.compile(r"\bTRUNCATE\b", re.IGNORECASE), "destructive SQL"),
    (re.compile(r"\bgit\s+push\b[^\n]*\s(--force|-f)\b"), "force push"),
    (re.compile(r"\bgit\s+reset\s+--hard\b"), "hard reset"),
    (re.compile(r"\bgit\s+(checkout|restore)\s+\.\b"), "discard local changes"),
    (re.compile(r"\bkubectl\s+delete\b"), "cluster deletion"),
    (re.compile(r"\bdocker\s+(rm\s+-f|system\s+prune)\b"), "container cleanup"),
]
SAFE_DELETE_PATTERNS = [
    re.compile(r"\brm\s+(-[^\n]*r[^\n]*f|-rf|-fr|--recursive)\b[^\n]*\b(node_modules|\.next|dist|__pycache__|\.cache|build|\.turbo|coverage)\b")
]


def load_state() -> dict[str, str]:
    if not STATE_PATH.exists():
        return {"mode": "off", "careful": "false", "freeze_dir": ""}
    data: dict[str, str] = {}
    for line in STATE_PATH.read_text(encoding="utf-8").splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key.strip()] = value.strip().strip('"')
    return data


def write_state(mode: str, careful: bool, freeze_dir: str) -> None:
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(
        "\n".join(
            [
                "version = 1",
                f'mode = "{mode}"',
                f"careful = {'true' if careful else 'false'}",
                f'freeze_dir = "{freeze_dir}"',
                f'updated_at = "{dt.datetime.utcnow().replace(microsecond=0).isoformat()}Z"',
                "",
            ]
        ),
        encoding="utf-8",
    )


def cmd_status(_: argparse.Namespace) -> int:
    if not STATE_PATH.exists():
        print("Guardrails are not configured")
        return 0
    print(STATE_PATH.read_text(encoding="utf-8").rstrip())
    return 0


def cmd_careful(_: argparse.Namespace) -> int:
    write_state("careful", True, "")
    print(STATE_PATH)
    return 0


def cmd_freeze(args: argparse.Namespace) -> int:
    freeze_dir = Path(args.path).expanduser().resolve()
    write_state("freeze", False, f"{freeze_dir}/")
    print(STATE_PATH)
    return 0


def cmd_guard(args: argparse.Namespace) -> int:
    freeze_dir = Path(args.path).expanduser().resolve()
    write_state("guard", True, f"{freeze_dir}/")
    print(STATE_PATH)
    return 0


def cmd_clear(_: argparse.Namespace) -> int:
    write_state("off", False, "")
    print(STATE_PATH)
    return 0


def cmd_check_command(args: argparse.Namespace) -> int:
    state = load_state()
    command = args.command
    if state.get("careful", "false") != "true":
        print("OK\tcareful mode is off")
        return 0

    for safe_pattern in SAFE_DELETE_PATTERNS:
        if safe_pattern.search(command):
            print("OK\tsafe exception")
            return 0

    for pattern, reason in DESTRUCTIVE_PATTERNS:
        if pattern.search(command):
            print(f"WARN\t{reason}\t{command}")
            return 1

    print("OK\tno destructive pattern detected")
    return 0


def cmd_check_path(args: argparse.Namespace) -> int:
    state = load_state()
    freeze_dir = state.get("freeze_dir", "")
    if not freeze_dir:
        print("ALLOW\tno freeze boundary")
        return 0

    target = str(Path(args.path).expanduser().resolve())
    normalized = freeze_dir.rstrip("/") + "/"
    if target == normalized.rstrip("/") or target.startswith(normalized):
        print(f"ALLOW\t{normalized}")
        return 0

    print(f"DENY\toutside freeze boundary\t{normalized}\t{target}")
    return 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser()
    subparsers = parser.add_subparsers(dest="command", required=True)

    status = subparsers.add_parser("status")
    status.set_defaults(func=cmd_status)

    careful = subparsers.add_parser("careful")
    careful.set_defaults(func=cmd_careful)

    freeze = subparsers.add_parser("freeze")
    freeze.add_argument("path")
    freeze.set_defaults(func=cmd_freeze)

    guard = subparsers.add_parser("guard")
    guard.add_argument("path")
    guard.set_defaults(func=cmd_guard)

    clear = subparsers.add_parser("clear")
    clear.set_defaults(func=cmd_clear)

    unfreeze = subparsers.add_parser("unfreeze")
    unfreeze.set_defaults(func=cmd_clear)

    check_command = subparsers.add_parser("check-command")
    check_command.add_argument("command")
    check_command.set_defaults(func=cmd_check_command)

    check_path = subparsers.add_parser("check-path")
    check_path.add_argument("path")
    check_path.set_defaults(func=cmd_check_path)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
