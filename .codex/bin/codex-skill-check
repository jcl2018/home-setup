#!/usr/bin/env python3
"""Validate the active Codex skill tree."""

from __future__ import annotations

from pathlib import Path


SKILLS_ROOT = Path.home() / ".codex" / "skills"
EXPECTED = {
    "office-hours",
    "plan-ceo-review",
    "plan-eng-review",
    "plan-design-review",
    "design-consultation",
    "investigate",
    "design-review",
    "review",
    "qa",
    "qa-only",
    "ship",
    "document-release",
    "retro",
    "careful",
    "freeze",
    "guard",
    "unfreeze",
    "home-health",
    "home-export",
}


def main() -> int:
    actual = {
        path.name
        for path in SKILLS_ROOT.iterdir()
        if path.is_dir() and not path.name.startswith(".")
    }
    missing = sorted(EXPECTED - actual)
    unexpected = sorted(actual - EXPECTED)
    problems: list[str] = []

    for name in sorted(EXPECTED):
        skill_dir = SKILLS_ROOT / name
        if not skill_dir.exists():
            continue
        if not (skill_dir / "SKILL.md").exists():
            problems.append(f"missing SKILL.md: {skill_dir}")
        if not (skill_dir / "agents" / "openai.yaml").exists():
            problems.append(f"missing agents/openai.yaml: {skill_dir}")

    if missing:
        problems.extend(f"missing skill dir: {name}" for name in missing)
    if unexpected:
        problems.extend(f"unexpected skill dir: {name}" for name in unexpected)

    if problems:
        print("FAIL")
        for problem in problems:
            print(problem)
        return 1

    print("PASS")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
