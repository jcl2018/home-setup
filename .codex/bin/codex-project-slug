#!/usr/bin/env python3
"""Print a stable project slug for the current path."""

from __future__ import annotations

import argparse
import os
import re
import subprocess
from pathlib import Path


def run_git(args: list[str], cwd: Path) -> str | None:
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=cwd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        return None
    return result.stdout.strip() or None


def sanitize(value: str) -> str:
    value = value.lower()
    value = re.sub(r"[^a-z0-9]+", "-", value)
    value = re.sub(r"-{2,}", "-", value)
    return value.strip("-") or "project"


def detect_root(start: Path) -> Path:
    git_root = run_git(["rev-parse", "--show-toplevel"], start)
    if git_root:
        return Path(git_root).resolve()
    return start.resolve()


def slug_from_remote(remote_url: str) -> str | None:
    cleaned = remote_url.strip().removesuffix(".git")
    cleaned = cleaned.replace("git@github.com:", "github.com/")
    match = re.search(r"github\.com/([^/]+)/([^/]+)$", cleaned)
    if match:
        return sanitize(f"{match.group(1)}-{match.group(2)}")
    parts = [part for part in re.split(r"[:/]+", cleaned) if part]
    if parts:
        return sanitize(parts[-1])
    return None


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--cwd", default=os.getcwd())
    args = parser.parse_args()

    home = Path.home().resolve()
    start = Path(args.cwd).expanduser().resolve()
    root = detect_root(start)

    if root == home or str(root).startswith(str(home / ".codex")):
        print("home-control")
        return 0

    remote = run_git(["remote", "get-url", "origin"], root)
    if remote:
        slug = slug_from_remote(remote)
        if slug:
            print(slug)
            return 0

    print(sanitize(root.name))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
