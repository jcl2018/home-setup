#!/usr/bin/env python3
"""Create and update the Codex project store."""

from __future__ import annotations

import argparse
import datetime as dt
import os
import re
import subprocess
from pathlib import Path


PROJECTS_ROOT = Path.home() / ".codex" / "projects"
STANDARD_DIRS = ("designs", "reviews", "qa", "ship", "retro")


def run_git(args: list[str], cwd: Path) -> str | None:
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=cwd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        return None
    return result.stdout.strip() or None


def sanitize(value: str) -> str:
    value = value.lower()
    value = re.sub(r"[^a-z0-9]+", "-", value)
    value = re.sub(r"-{2,}", "-", value)
    return value.strip("-") or "artifact"


def detect_root(start: Path) -> Path:
    git_root = run_git(["rev-parse", "--show-toplevel"], start)
    if git_root:
        return Path(git_root).resolve()
    return start.resolve()


def detect_slug(start: Path, explicit_slug: str | None) -> str:
    if explicit_slug:
        return sanitize(explicit_slug)

    home = Path.home().resolve()
    root = detect_root(start)
    if root == home or str(root).startswith(str(home / ".codex")):
        return "home-control"

    remote = run_git(["remote", "get-url", "origin"], root)
    if remote:
        cleaned = remote.removesuffix(".git").replace("git@github.com:", "github.com/")
        match = re.search(r"github\.com/([^/]+)/([^/]+)$", cleaned)
        if match:
            return sanitize(f"{match.group(1)}-{match.group(2)}")

    return sanitize(root.name)


def project_root(cwd: Path, slug: str | None) -> tuple[Path, Path, str]:
    root = detect_root(cwd)
    resolved_slug = detect_slug(cwd, slug)
    return root, PROJECTS_ROOT / resolved_slug, resolved_slug


def ensure_layout(cwd: Path, slug: str | None) -> Path:
    repo_root, target, resolved_slug = project_root(cwd, slug)
    target.mkdir(parents=True, exist_ok=True)
    for name in STANDARD_DIRS:
        (target / name).mkdir(exist_ok=True)

    project_file = target / "project.md"
    if not project_file.exists():
        project_file.write_text(
            "\n".join(
                [
                    f"# {resolved_slug}",
                    "",
                    "- Status: active",
                    f"- Root: {repo_root}",
                    "- Workflow: office-hours -> plan-ceo-review -> plan-eng-review -> plan-design-review -> investigate or repo work -> review -> qa or qa-only -> ship -> document-release -> retro",
                    f"- Last updated: {dt.datetime.utcnow().replace(microsecond=0).isoformat()}Z",
                    "",
                ]
            ),
            encoding="utf-8",
        )
    return target


def cmd_ensure(args: argparse.Namespace) -> int:
    target = ensure_layout(Path(args.cwd).expanduser().resolve(), args.slug)
    print(target)
    return 0


def cmd_stamp(args: argparse.Namespace) -> int:
    target = ensure_layout(Path(args.cwd).expanduser().resolve(), args.slug)
    category = sanitize(args.category)
    if category not in STANDARD_DIRS:
        raise SystemExit(f"Unsupported category: {args.category}")
    stamp = dt.datetime.utcnow().strftime("%Y%m%d-%H%M%S")
    name = sanitize(args.name)
    path = target / category / f"{stamp}-{name}.{args.ext}"
    if not path.exists():
        path.write_text("", encoding="utf-8")
    print(path)
    return 0


def cmd_append(args: argparse.Namespace) -> int:
    target = ensure_layout(Path(args.cwd).expanduser().resolve(), args.slug)
    rel_path = Path(args.relpath)
    file_path = target / rel_path
    file_path.parent.mkdir(parents=True, exist_ok=True)
    with file_path.open("a", encoding="utf-8") as handle:
        handle.write(args.payload)
        if not args.payload.endswith("\n"):
            handle.write("\n")
    print(file_path)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser()
    subparsers = parser.add_subparsers(dest="command", required=True)

    ensure = subparsers.add_parser("ensure")
    ensure.add_argument("--cwd", default=os.getcwd())
    ensure.add_argument("--slug")
    ensure.set_defaults(func=cmd_ensure)

    stamp = subparsers.add_parser("stamp")
    stamp.add_argument("category")
    stamp.add_argument("name")
    stamp.add_argument("--cwd", default=os.getcwd())
    stamp.add_argument("--slug")
    stamp.add_argument("--ext", default="md")
    stamp.set_defaults(func=cmd_stamp)

    append = subparsers.add_parser("append")
    append.add_argument("relpath")
    append.add_argument("payload")
    append.add_argument("--cwd", default=os.getcwd())
    append.add_argument("--slug")
    append.set_defaults(func=cmd_append)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
